# Clipper card account configuration
# Copy to clipper.toml and fill in your values

[[accounts]]
name = "alice"
email = "alice@example.com"
password = "your-clipper-password"
cards = ["1234567890"]

[[accounts]]
name = "bob"
email = "bob@example.com"
password = "your-clipper-password"
cards = ["0987654321", "1111111111"]
